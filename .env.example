# AWS Credentials
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET=your-bucket-name

# API Keys
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key
OPENWEATHER_API_KEY=your_openweather_key
FRED_API_KEY=your_fred_api_key

# SEC EDGAR — required by edgar_pipeline.py
# Format: "CompanyName AdminEmail your@email.com"  (SEC requirement per https://www.sec.gov/developer)
EDGAR_USER_AGENT=YourName your@email.com

# Airflow — required for Airflow secret encryption and webserver session security
# Generate Fernet key: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=your_fernet_key_here
AIRFLOW__CORE__FERNET_KEY=your_fernet_key_here

# Generate secret key: python -c "import secrets; print(secrets.token_hex(32))"
AIRFLOW__WEBSERVER__SECRET_KEY=your_webserver_secret_key_here
